# ==============================================================================
# GLOBAL CONFIGURATION
# ==============================================================================

DOMAIN=example.com

# --- Networks ---
NETWORK_DATA=data
NETWORK_INTERNAL=internal

# --- Timezone ---
TZ=Africa/Casablanca

# --- Health Checks ---
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=3
HEALTHCHECK_START_PERIOD=40s

# ==============================================================================
# SMTP
# ==============================================================================

SMTP_HOST=mail.example.com
SMTP_PORT=465
SMTP_USERNAME=no-reply@example.com
SMTP_PASSWORD=changeme
SMTP_FROM=no-reply@example.com
SMTP_USE_TLS=false
SMTP_USE_SSL=true
SMTP_TIMEOUT=10

# ==============================================================================
# TRAEFIK
# ==============================================================================

TRAEFIK_IMAGE=traefik
TRAEFIK_IMAGE_TAG=v3.3
TRAEFIK_HOST=traefik
TRAEFIK_DOMAIN=proxy.${DOMAIN}
TRAEFIK_CERTRESOLVER=letsencrypt
ACME_EMAIL=admin@example.com

# --- ACME challenge: http or dns ---
TRAEFIK_ACME_CHALLENGE=http

# --- DNS challenge only ---
TRAEFIK_DNS_PROVIDER=
TRAEFIK_DNS_TOKEN=

# ==============================================================================
# POSTGRES
# ==============================================================================

POSTGRES_IMAGE=postgres
POSTGRES_IMAGE_TAG=18
POSTGRES_HOST=postgres
POSTGRES_SUPER_USER=postgres
POSTGRES_SUPER_PASSWORD=changeme
POSTGRES_MEMORY_LIMIT=1G
POSTGRES_CPU_LIMIT=1.0
POSTGRES_MEMORY_RESERVATION=512M
POSTGRES_CPU_RESERVATION=0.5

# --- Authentik Database ---
POSTGRES_AUTHENTIK_USER=authentik
POSTGRES_AUTHENTIK_PASSWORD=changeme
POSTGRES_AUTHENTIK_DB=authentik

# ==============================================================================
# REDIS
# ==============================================================================

REDIS_IMAGE=redis
REDIS_IMAGE_TAG=7-alpine
REDIS_HOST=redis
REDIS_PASSWORD=changeme
REDIS_MEMORY_LIMIT=512M
REDIS_CPU_LIMIT=0.5
REDIS_MEMORY_RESERVATION=256M
REDIS_CPU_RESERVATION=0.25

# ==============================================================================
# AUTHENTIK
# ==============================================================================

AUTHENTIK_IMAGE=ghcr.io/goauthentik/server
AUTHENTIK_TAG=2024.12.2
AUTHENTIK_SERVER_HOST=auth-server
AUTHENTIK_WORKER_HOST=auth-worker
AUTHENTIK_DOMAIN=sso.${DOMAIN}
AUTHENTIK_HOST=https://sso.${DOMAIN}
AUTHENTIK_PORT=9000
AUTHENTIK_SECRET_KEY=changeme_min_50_chars
AUTHENTIK_SERVER_MEMORY_LIMIT=1G
AUTHENTIK_SERVER_CPU_LIMIT=1.0
AUTHENTIK_SERVER_MEMORY_RESERVATION=512M
AUTHENTIK_SERVER_CPU_RESERVATION=0.5
AUTHENTIK_WORKER_MEMORY_LIMIT=1G
AUTHENTIK_WORKER_CPU_LIMIT=1.0
AUTHENTIK_WORKER_MEMORY_RESERVATION=512M
AUTHENTIK_WORKER_CPU_RESERVATION=0.5

# ==============================================================================
# DOZZLE
# ==============================================================================

DOZZLE_IMAGE=amir20/dozzle
DOZZLE_TAG=v8.14.1
DOZZLE_HOST=dozzle
DOZZLE_DOMAIN=logs.${DOMAIN}
DOZZLE_PORT=8080
DOZZLE_LEVEL=error
DOZZLE_FILTER=status=running
DOZZLE_MEMORY_LIMIT=128M
DOZZLE_CPU_LIMIT=0.25
DOZZLE_MEMORY_RESERVATION=64M
DOZZLE_CPU_RESERVATION=0.1

# ==============================================================================
# BACKUPS
# ==============================================================================

POSTGRES_BACKUP_IMAGE=registry.${DOMAIN}/postgres-backup
POSTGRES_BACKUP_IMAGE_TAG=1.0.0
BACKUP_PATH=./backup/backups
BACKUP_SCHEDULE=@daily
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6
BACKUP_WEBHOOK_SUCCESS_URL=
BACKUP_WEBHOOK_ERROR_URL=

# --- Rclone destination (e.g. s3:bucket/path or sftp:path) ---
RCLONE_DEST=

# --- S3/MinIO ---
BACKUP_S3_ENDPOINT=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=

# --- SFTP ---
BACKUP_SFTP_HOST=
BACKUP_SFTP_USER=

# ==============================================================================
# REGISTRY (only used when REGISTRY_LOCAL=true)
# ==============================================================================

REGISTRY_LOCAL=false
REGISTRY_IMAGE=registry
REGISTRY_IMAGE_TAG=2
REGISTRY_HOST=registry
REGISTRY_DOMAIN=registry.${DOMAIN}
REGISTRY_PORT=5000
REGISTRY_STORAGE_DELETE_ENABLED=true
REGISTRY_MEMORY_LIMIT=256M
REGISTRY_CPU_LIMIT=0.5
REGISTRY_MEMORY_RESERVATION=128M
REGISTRY_CPU_RESERVATION=0.25